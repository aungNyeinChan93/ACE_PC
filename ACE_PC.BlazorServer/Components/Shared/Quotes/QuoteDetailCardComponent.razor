@inject LikesUseCase LikesUseCase;
@inject ISnackbar Snackbar;


<div class="col-lg-12">
    <div class="card rounded-4 overflow-hidden border-0 shadow-lg">

        <!-- Optional Cover Image -->
        @*
                <img src="https://picsum.photos/1200/500"
                     class="card-img-top"
                     style="height:350px; object-fit:cover;"
                     alt="Blog Image">
                *@

        <!-- Card Body -->
        <div class="card-body p-md-5 d-flex flex-column p-4">

            <!-- Category -->
            <div class="mb-3">
                <span class="badge bg-primary fs-6 rounded-pill px-3 py-2">
                    @Quote.Category
                </span>
            </div>

            <!-- Title -->
            <h1 class="fw-bold display-6 mb-3">
                @Quote.Title
            </h1>

            <!-- Content -->
            <p class="text-muted fs-5 lh-lg">
                @Quote.Content
            </p>

            <!-- Author Section -->
            <div class="d-flex justify-content-between align-items-center border-top mt-4 pt-4">

                <!-- Author -->
                <div class="d-flex align-items-center gap-3">

                    <!-- Avatar -->
                    <div class="bg-primary rounded-circle d-flex justify-content-center align-items-center text-white"
                         style="width:50px; height:50px;">
                        @if (!string.IsNullOrWhiteSpace(Quote.Author))
                        {
                            @Quote.Author.Substring(0, 1).ToUpper()
                        }
                        else
                        {
                            <span>?</span>
                        }
                    </div>

                    <div>
                        <h6 class="fw-bold mb-0">
                            @Quote.Author
                        </h6>

                        <small class="text-muted">
                            May 27, 2026
                        </small>
                    </div>
                </div>

                <!-- More Button -->
                <div class="dropdown">
                    <button class="btn btn-light rounded-circle border"
                            data-bs-toggle="dropdown">

                        <i class="bi bi-three-dots"></i>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end shadow">
                        <li>
                            <a class="dropdown-item" href="#">
                                <i class="bi bi-bookmark me-2"></i>
                                Save
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="#">
                                <i class="bi bi-share me-2"></i>
                                Share sdfsdfasdfasdfa
                            </a>
                        </li>

                        <li>
                            <hr class="dropdown-divider">
                        </li>

                        <li>
                            <a class="dropdown-item text-danger" href="#">
                                <i class="bi bi-flag me-2"></i>
                                Report
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Interaction Section -->
            <div class="border-top mt-4 pt-3">

                <div class="row text-center">

                    <!-- Like -->
                    <div class="col">
                        <button @onclick="LikeToogleAction" class="btn btn-light w-100 rounded-3 py-2">
                            @if (IsLike)
                            {
                                <i class="bi bi-heart-fill text-danger me-2"></i>
                            }
                            else
                            {
                                <i class="bi bi-heart text-danger me-2"></i>
                            }
                            Like
                        </button>
                    </div>

                    <!-- Comment -->
                    <div class="col">
                        <button @onclick="@(() => OnComment.InvokeAsync(IsComment = !IsComment))" class="btn btn-light w-100 rounded-3 py-2">
                            <i class="bi bi-chat-dots text-primary me-2"></i>
                            Comment
                        </button>
                    </div>

                    <!-- Share -->
                    <div class="col">
                        <a href="/quotes" class="btn btn-light w-100 rounded-3 py-2">
                            <i class="bi bi-send text-success me-2"></i>
                            Back
                        </a>
                    </div>

                </div>

                <!-- Stats -->
                <div class="d-flex justify-content-between mt-3 px-2">

                    <small class="text-muted">
                        <i class="bi bi-heart-fill text-danger"></i>
                        @(Quote.Likes.Count)
                    </small>

                    <small class="text-muted">
                        24 Comments
                    </small>
                </div>
            </div>

        </div>
    </div>
</div>


@code {

    [Parameter]
    public UserDto AuthUser { get; set; } = new();

    [Parameter]
    public QuotesDto Quote { get; set; } = new();

    [Parameter]
    public EventCallback<bool> OnComment { get; set; }

    public bool IsComment { get; set; } = false;

    public bool IsLike { get; set; } = false;


    private Task LikeState()
    {
        IsLike = Quote.Likes?.Any(l => l.UserId == AuthUser.UserId) ?? false;
        return Task.CompletedTask;
    }

    [Parameter]
    public EventCallback LoadQuote { get; set; }

    private async Task LikeToogleAction()
    {
        try
        {
            var request = new LikeCreateRequest
            {
                QuoteId = Quote.Id,
                UserId = AuthUser.UserId
            };

            var response = await LikesUseCase.LikeToogle(request);

            if (response.IsError)
            {
                if (response.ResponseType == Domain.Helpers.ReqResHelper.EnumResponseType.Pending)
                {
                    Snackbar.Add(response.ResponseMessage);
                    return;
                }
                if (response.ResponseType == Domain.Helpers.ReqResHelper.EnumResponseType.ValidationError)
                {
                    Snackbar.Add(response.ResponseMessage);
                    return;
                }
                if (response.ResponseType == Domain.Helpers.ReqResHelper.EnumResponseType.SystemError)
                {
                    Snackbar.Add(response.ResponseMessage, Severity.Error);
                    return;
                }
            }
            if (response.IsSuccess)
            {
                await this.LoadQuote.InvokeAsync();
                IsLike = response.Data!.IsLike;
                Snackbar.Add(response.ResponseMessage, Severity.Success);
                return;
            }
        }
        catch (Exception)
        {

            throw;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await LikeState();
    }
    

}