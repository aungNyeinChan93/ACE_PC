@using ACE_PC.BlazorServer.Components.Shared.Quotes


@if (Quote is null)
{
    <LoadingComponent />
}
else
{

    <div class="container py-5">
        <div class="row justify-content-center">

            <!-- Quote Card Section -->
            <QuoteDetailCardComponent LoadQuote="LoadQuote" AuthUser="AuthUser" Quote="Quote" OnComment="HandleIsComment" />

            <!-- Comment Box Section-->
            @if (IsComment)
            {
                <div class="p-4">
                    <QuoteCommetCreate Quote="Quote" LoadQuote="LoadQuote" />
                </div>
            }

            <!-- Comment Show Section-->
            <QuoteCommentCard Comments="Quote.Comments" />
        </div>
    </div>
}


<pre>
    @* @(JsonConvert.SerializeObject(Quote,Formatting.Indented)) *@
</pre>

@code {
    [Parameter]
    public UserDto? AuthUser { get; set; }

    [Parameter]
    public QuotesDto Quote { get; set; } = new();

    public bool IsComment { get; set; }

    [Parameter]
    public EventCallback LoadQuote { get; set; }


    public async Task HandleIsComment(bool status)
    {
        IsComment = status ? true : false;
    }



}