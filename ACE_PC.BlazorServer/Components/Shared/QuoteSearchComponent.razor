@inject QuoteUseCases QuoteUseCases

<div class="container pt-4">
    <div class="row justify-content-end">
        <div class="col-md-6 col-lg-5">

            <div class="d-flex align-items-center rounded-pill border bg-white px-3 py-1 shadow-sm">

                <span class="text-muted d-flex align-items-center me-2">
                    <i class="bi bi-search fs-5 opacity-75"></i>
                </span>

                <input @bind="SearchKey"
                       @bind:event="oninput"
                       class="form-control border-0 bg-transparent p-2 shadow-none"
                       placeholder="Search quotes, authors..." />

                @if (!string.IsNullOrEmpty(SearchKey))
                {
                    <button class="btn btn-light text-muted rounded-circle d-flex align-items-center justify-content-center me-2 p-0"
                            type="button"
                            @onclick="ClearSearch"
                            style="width: 30px; height: 30px; min-width: 30px;"
                            title="Clear search">
                        <i class="bi bi-x fs-5"></i>
                    </button>
                }

                <button class="btn btn-info rounded-pill fw-semibold text-nowrap px-4 py-2 text-white shadow-sm"
                        type="button"
                        @onclick="ExecuteSearch">
                    Search
                </button>

            </div>

        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback<List<QuotesDto>> OnSearchCompleted { get; set; }

    public string SearchKey { get; set; } = "";

    private async Task ExecuteSearch()
    {
        var request = new QuoteSearchRequest
        {
            QuoteTitle = SearchKey,
            AuthorName = SearchKey,
        };

        var response = await QuoteUseCases.GetBySearchKey(searchReq: request);
        if (response.IsSuccess && response.Data?.Quotes is not null)
        {
            await OnSearchCompleted.InvokeAsync(response.Data.Quotes);
        }
    }

    private async Task ClearSearch()
    {
        SearchKey = "";
        await ExecuteSearch();
    }
}