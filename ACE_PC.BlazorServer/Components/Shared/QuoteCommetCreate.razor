<!-- Create Comment Box -->
<div class="card rounded-4 mb-4 border-0 shadow-sm">
    <div class="card-body">

        <div class="d-flex gap-3">

            <!-- Avatar -->
            <div class="rounded-circle bg-primary d-flex justify-content-center align-items-center fw-bold text-white"
                 style="width:45px; height:45px; min-width:45px;">
                U
            </div>

            <!-- Input Area -->
            <div class="flex-grow-1">

                <textarea class="form-control bg-light rounded-4 border-0 p-3"
                          rows="3"
                          placeholder="Write a comment..."
                          @bind="NewComment"></textarea>

                <div class="d-flex justify-content-end mt-3">

                    <button class="btn btn-primary rounded-pill px-4"
                            @onclick="AddComment"
                            disabled="@IsPosting">

                        @if (IsPosting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            @* Posting... *@
                        }
                        else
                        {
                            <i class="bi bi-send me-2"></i>
                            @* Post Comment *@
                        }

                    </button>

                </div>

            </div>
        </div>

    </div>
</div>

@code {



    private string NewComment = "";
    private bool IsPosting = false;

    private List<CommentVm> Comments = new()
    {
        new CommentVm { UserName = "john", Content = "Nice post!", Time = "2h ago" },
        new CommentVm { UserName = "alice", Content = "Very helpful 👍", Time = "1d ago" }
    };

    private async Task AddComment()
    {
        if (string.IsNullOrWhiteSpace(NewComment))
            return;

        IsPosting = true;

        // simulate API delay
        await Task.Delay(800);

        Comments.Insert(0, new CommentVm
        {
            UserName = "current_user",
            Content = NewComment,
            Time = "Just now"
        });

        NewComment = "";

        IsPosting = false;
    }

    public class CommentVm
    {
        public string UserName { get; set; } = "";
        public string Content { get; set; } = "";
        public string Time { get; set; } = "";
    }
}