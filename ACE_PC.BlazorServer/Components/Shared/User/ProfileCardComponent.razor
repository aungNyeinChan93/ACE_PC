@using ACE_PC.Domain.Dtos.Users
@inject NavigationManager NavigationManager;


<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">

            <div class="card rounded-4 overflow-hidden border-0 shadow-lg">

                <!-- Profile Header -->
                <div class="bg-dark p-4 text-center text-white">

                    <img src="@Assets[$"/images/profiles/p1.png"]"
                         class="rounded-circle border border-4 border-white shadow"
                         width="120"
                         height="120" />

                    <h3 class="mb-1 mt-3">@AuthUser?.Name.ToUpper()</h3>

                    <span class="badge bg-light text-dark px-3 py-2">
                        @AuthUser?.Role?.Name
                    </span>

                </div>

                <!-- Profile Body -->
                <div class="card-body p-4">

                    <div class="mb-3">
                        <label class="fw-bold text-muted">User ID</label>
                        <div class="form-control">@AuthUser?.UserId</div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold text-muted">Email</label>
                        <div class="form-control">@AuthUser?.Email</div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold text-muted">Password</label>
                        <div class="form-control">••••••••</div>
                    </div>

                    <!-- Stats -->
                    <div class="row mt-4 text-center">

                        <div class="col-4">
                            <a href="/quotes/myQuotes" class="text-decoration-none">

                                <div class="rounded-3 border p-3 shadow-sm">
                                    <h4>@AuthUser?.Quotes!.Count</h4>
                                    <small class="text-muted">Quotes</small>
                                </div>
                            </a>
                        </div>

                        <div class="col-4">
                            <div class="rounded-3 border p-3 shadow-sm">
                                <h4>@AuthUser?.Comments!.Count</h4>
                                <small class="text-muted">Comments</small>
                            </div>
                        </div>

                        <div class="col-4">
                            <div class="rounded-3 border p-3 shadow-sm">
                                <h4>@AuthUser?.Likes!.Count</h4>
                                <small class="text-muted">Likes</small>
                            </div>
                        </div>

                    </div>

                </div>

                <!-- Footer -->
                <div class="card-footer border-0 bg-white pb-4 text-center">

                    <button @onclick="EditUserAction" class="btn btn-dark rounded-pill px-4">
                        Edit Profile
                    </button>

                    <AuthorizeView>
                        <Authorized>
                            <button @onclick="LogoutAction" class="btn btn-outline-danger rounded-pill ms-2 px-4">
                                Logout
                            </button>
                        </Authorized>
                    </AuthorizeView>

                </div>

            </div>

        </div>
    </div>
</div>

@code {
    [Parameter]
    public UserDto? AuthUser { get; set; }

    private async Task EditUserAction()
    {
        NavigationManager.NavigateTo($"/users/edit/{AuthUser!.UserId}");
    }

    private async Task LogoutAction()
    {
        NavigationManager.NavigateTo("/logout");
    }

