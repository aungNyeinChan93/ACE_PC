<div class="card h-100 border-0 shadow-sm">

    <!-- Header -->
    <div class="card-header border-0 bg-white pt-3">

        <div class="d-flex justify-content-between align-items-center">

            <div class="d-flex align-items-center gap-2">

                <div class="rounded-circle bg-primary d-flex justify-content-center align-items-center text-white"
                     style="width:45px;height:45px;">
                    @MyQuote.Author[..1].ToUpper()
                </div>

                <div>
                    <div class="fw-semibold">@MyQuote.Author</div>
                    <small class="text-muted">Quote #@MyQuote.Id</small>
                </div>

            </div>

            <button class="btn btn-sm btn-light rounded-circle">
                <i class="bi bi-three-dots"></i>
            </button>

        </div>

    </div>

    <!-- Body -->
    <div class="card-body">

        <span class="badge bg-light text-dark mb-3 border">
            @MyQuote.Category
        </span>

        <h5 class="fw-bold">
            @MyQuote.Title
        </h5>

        <p class="text-muted mb-0">
            "@MyQuote.Content"
        </p>

    </div>

    <!-- Footer -->
    <div class="card-footer border-0 bg-white">

        <div class="d-flex justify-content-between align-items-center">

            <div class="d-flex gap-2">

                <button class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-heart-fill me-1"></i>
                    @MyQuote.Likes.Count
                </button>

                <button class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-chat-dots me-1"></i>
                    @MyQuote.Comments.Count
                </button>

            </div>

            <button class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-bookmark"></i>
            </button>

        </div>

    </div>

</div>

@code {
    private Quote MyQuote = new()
    {
        Id = 12,
        Title = "Sit minus dolores c",
        Content = "Eveniet quas enim q",
        Author = "admin",
        AuthorId = 0,
        Category = "22",
        CategoryId = 0,
        Likes = new() { "User1", "User2", "User3" },
        Comments = new() { "Great quote!", "Nice one!" }
    };

    public class Quote
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Content { get; set; } = "";
        public string Author { get; set; } = "";
        public int AuthorId { get; set; }
        public string Category { get; set; } = "";
        public int CategoryId { get; set; }
        public List<string> Likes { get; set; } = new();
        public List<string> Comments { get; set; } = new();
    }
}