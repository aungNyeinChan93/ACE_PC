

<div class="card quote-card border-0 shadow">

    <div class="quote-header"></div>

    <div class="card-body p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <span class="badge category-badge px-3 py-2">
                🚀 @QuoteDto.Category
            </span>

            <button class="menu-btn">
                <i class="bi bi-three-dots"></i>
            </button>

        </div>

        <div class="quote-icon mb-4">
            <i class="bi bi-chat-quote-fill"></i>
        </div>

        <h4 class="fw-bold quote-title">
            @QuoteDto.Title
        </h4>

        <p class="quote-content">
            @* @QuoteDto.Content.ToString().Substring(0,10) *@
            @(QuoteDto.Content.Length > 50
                ? QuoteDto.Content.Substring(0, 50) + "..."
                : QuoteDto.Content)

        </p>

    </div>

    <div class="card-footer border-0 bg-white p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div class="d-flex align-items-center gap-3">

                <div class="author-avatar">
                    @QuoteDto.Author[0].ToString().ToUpper()
                </div>

                <div>
                    <div class="fw-bold">
                        @QuoteDto.Author
                    </div>

                    <small class="text-muted">
                        Quote #@QuoteDto.Id
                    </small>
                </div>

            </div>

        </div>

        <div class="d-flex gap-2">

            <button class="action-btn like-btn flex-fill">
                ❤️ @QuoteDto.Likes.Count
            </button>

            <button class="action-btn comment-btn flex-fill">
                💬 @QuoteDto.Comments.Count
            </button>

            @* <button class="action-btn detail-btn flex-fill">
                <i class="bi bi-eye-fill me-1"></i>
                 Detail
            </button>  *@

            <button class="action-btn detail-btn flex-fill">
                <i class="bi bi-arrow-right-circle-fill me-2"></i>
                View Detail
            </button>

        </div>

    </div>

</div>


@code {

    [Parameter]
    public QuotesDto QuoteDto { get; set; } = new();

    private Quote MyQuote = new()
    {
        Id = 12,
        Title = "Sit minus dolores c",
        Content = "Eveniet quas enim q",
        Author = "admin",
        AuthorId = 0,
        Category = "22",
        CategoryId = 0,
        Likes = new() { "User1", "User2", "User3" },
        Comments = new() { "Great quote!", "Nice one!" }
    };

    public class Quote
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Content { get; set; } = "";
        public string Author { get; set; } = "";
        public int AuthorId { get; set; }
        public string Category { get; set; } = "";
        public int CategoryId { get; set; }
        public List<string> Likes { get; set; } = new();
        public List<string> Comments { get; set; } = new();
    }
}

<style>
