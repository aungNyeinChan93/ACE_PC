@page "/quotes"
@using ACE_PC.BlazorServer.Components.Shared
@inject QuoteUseCases QuoteUseCases;
@attribute [Authorize];
@inject NavigationManager NavigationManager

<section>
    <h3 class="text-info mb-3">Quotes List</h3>

    <div>
        <button @onclick="@(() => NavigationManager.NavigateTo("/quotes/create"))" type="button" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Create
        </button>
    </div>
    <QuoteTableComponent Quotes="MyQuotes" /> 
</section>


<br />
<hr />
<pre>
     @(JsonConvert.SerializeObject(MyQuotes, Formatting.Indented))  
</pre>

@code {
    public List<QuotesDto> MyQuotes { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        await this.LoadQuotes();

    }

    private async Task LoadQuotes()
    {
        var response = await QuoteUseCases.GetAllQuotes();
        if (response.IsSuccess)
        {
            var quotes = response.Data!.Quotes;
            if (quotes is not null)
            {
                MyQuotes.Clear();
                MyQuotes = [.. quotes];
            }
        }
    }


}
