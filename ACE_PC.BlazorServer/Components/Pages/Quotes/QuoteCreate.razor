@page "/quotes/create"
@inject AuthenticationStateProvider AuthenticationStateProvider;
@inject CategoriesUseCase CategoriesUseCase;
@inject QuoteUseCases QuoteUseCases;
@inject NavigationManager NavigationManager;
@inject ISnackbar Snackbar;

<h3 class="mb-4">Create Quote</h3>

<EditForm Model="Quote" OnValidSubmit="CreateQuoteAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <!-- Title -->
    <div class="mb-3">
        <label class="form-label">Title</label>
        <InputText class="form-control"
                   @bind-Value="Quote.Title" />
    </div>

    <!-- Content -->
    <div class="mb-3">
        <label class="form-label">Content</label>
        <InputTextArea class="form-control"
                       rows="5"
                       @bind-Value="Quote.Content" />
    </div>

    @* <InputNumber hidden @bind-Value="UserId"/> *@

   
    <!-- Category Select -->
    <div class="mb-3">
        <label class="form-label">Category</label>

        <InputSelect class="form-select"
                     @bind-Value="Quote.CategoryId">

            <option>-- Select Category --</option>

            @foreach (var category in Categories)
            {
                <option value="@category.CategoryId">
                    @category.Name
                </option>
            }

        </InputSelect>
    </div>

    <button type="submit" class="btn btn-primary">
        Create Quote
    </button>
</EditForm>

@code {


    public List<Category> Categories { get; set; } = [];

    private CreateQuoteDto Quote = new();

    public int UserId { get; set; }

    private async Task CreateQuoteAsync()
    {
        Console.WriteLine("Quote Created");
        var response = await QuoteUseCases.CreateQuote(Quote);
        if (response.IsSuccess)
        {
            Console.WriteLine($"Create Success - {response.Data!.Quote!.Title} ");
            Snackbar.Add(response.ResponseMessage);
            NavigationManager.NavigateTo("/quotes");
        }

    }

    private async Task LoadUserId()
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var authUser = state.User;
        var userId = int.Parse(authUser.FindFirstValue(ClaimTypes.NameIdentifier)!);
        UserId = userId;
        Quote.UserId = UserId;
    }

    protected override async Task OnInitializedAsync()
    {
        // return base.OnInitializedAsync();
        await this.LoadUserId();
        await this.LoadCategories();
    }

    private async Task LoadCategories()
    {
        var response = await CategoriesUseCase.GetAllAsync();
        if (response.IsSuccess)
        {
            var categories = response.Data!.Categoreis;
            if (categories is not null || categories!.Count > 0)
            {
                Categories = [.. categories];
            }
        }
    }

    private async Task DeleteQuote()
    {
        
    }
}