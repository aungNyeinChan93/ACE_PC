@page "/quotes/detail/{quoteId:int}"
@inject QuoteUseCases QuoteUseCases;
@* @inject UserUseCases UserUseCases; *@

@attribute [Authorize(Roles = "user,admin")]

@if (Quote is not null)
{
    <QuoteDetailComponent Quote="Quote" LoadQuote="LoadQuote" />

   

}
else
{
    <LoadingComponent />
}

<pre>
</pre>

@code {
    [Parameter]
    public int QuoteId { get; set; }

    public QuotesDto Quote { get; set; } = new();


    // private async Task LoadAuthUser()
    // {
    //     var authUser = await UserUseCases.GetAuthUser();
    //     if (authUser is not null)
    //     {
    //         AuthUser = authUser ?? new();
    //     }
    // }


    private async Task LoadQuote()
    {
        var response = await QuoteUseCases.GetByIdAsync(QuoteId);
        if (response.IsSuccess)
        {
            var quote = response.Data!.QuoteDto;
            if (quote is not null)
            {
                Quote = quote;
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await this.LoadQuote();
    }
}
