@page "/categories"
@inject CategoriesUseCase CategoriesUseCase;
@inject NavigationManager NavigationManager;
@inject IToastService toastService
@attribute [Authorize(Roles = "admin,user")]



<section class="container mt-4">

    <PageTitleComponent  TitleModel="TitleModel">
        <Actions>
            <a class="btn btn-primary" href="/categories/create">Add</a>
        </Actions>
    </PageTitleComponent>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">
                <i class="bi bi-tags-fill me-2"></i>
                Category List
            </h4>

            <span class="badge bg-light text-dark">
                Total: @Categories.Count
            </span>
        </div>

        <div class="card-body">

            @if (Categories is not null && Categories.Count > 0)
            {
                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead class="table-light">
                            <tr>
                                <th width="100">ID</th>
                                <th>Category Name</th>
                                <AuthorizeView Roles="admin">
                                    <Authorized>
                                        <th width="200">Actions</th>
                                    </Authorized>
                                    <NotAuthorized>
                                        <th width="200"></th>
                                    </NotAuthorized>
                                </AuthorizeView>
                                
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var category in Categories)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-secondary">
                                            #@category.CategoryId
                                        </span>
                                    </td>

                                    <td>
                                        <strong>@category.Name</strong>
                                    </td>

                                    <td>
                                        <div class="btn-group">

                                            @* <button class="btn btn-outline-primary btn-sm">
                                                <i class="bi bi-pencil-square"></i>
                                                View
                                            </button> *@

                                            <AuthorizeView Roles="admin">
                                                <Authorized>
                                                    @* <button class="btn btn-outline-primary btn-sm">
                                                        <i class="bi bi-pencil-square"></i>
                                                        Edit
                                                    </button> *@
                                                    <button class="btn btn-outline-danger btn-sm"
                                                            @onclick="() =>
                                                            {
                                                                DeleteId = category.CategoryId;
                                                                Modal.Show();
                                                            }">
                                                        <i class="bi bi-trash"></i>
                                                        Delete
                                                    </button>

                                                </Authorized>
                                            </AuthorizeView>

                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>

                </div>
            }
            else
            {
                <div class="text-center py-5">

                    <i class="bi bi-folder-x display-1 text-secondary"></i>

                    <h5 class="mt-3">
                        No Categories Found
                    </h5>

                    <p class="text-muted">
                        There are currently no categories available.
                    </p>

                </div>
            }

        </div>
    </div>

    <AppModal @ref="Modal">

        <Title>
            <span class="text-danger">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Confirm Delete
            </span>
        </Title>

        <Body>
            <p class="mb-0">
                Are you sure you want to delete this category?
            </p>

            <small class="text-muted">
                This action cannot be undone.
            </small>
        </Body>

        <Footer>
            <button class="btn btn-secondary"
                    @onclick="() => Modal.Close()">
                Cancel
            </button>

            <button class="btn btn-danger"
                    @onclick="DeleteCategory">
                <i class="bi bi-trash"></i>
                Delete
            </button>
        </Footer>

    </AppModal>
</section>
@code {

    public BaseTitle TitleModel { get; set; } = new BaseTitle
    {
        Icon = "bi bi-tags-fill",
        Subtitle = "Manage your categories",
        Title = "Category List"
    };

    public List<Category> Categories { get; set; } = [];

    public AppModal Modal { get; set; } = new();

    public int DeleteId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await this.LoadCategories();
        // return base.OnInitializedAsync();
    }

    private async Task LoadCategories()
    {
        var response = await CategoriesUseCase.GetAllAsync();
        if (response.IsError)
        {
            NavigationManager.NavigateTo("/");
        }

        var categories = response.Data!.Categoreis;

        if (categories!.Count >= 1)
        {
            Categories = [.. categories];
        }


    }

    private async Task DeleteCategory()
    {
        var response = await CategoriesUseCase.DeleteCategory(DeleteId);
        if (response.IsSuccess)
        {
            toastService.ShowSuccess("Delete Success");
            NavigationManager.NavigateTo("/categories");
            Modal.Close();
            await this.LoadCategories();
        }
    }

}



