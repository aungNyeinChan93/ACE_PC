@page "/login"
@layout EmptyLayout

@inject AuthUseCase AuthUseCase;
@inject NavigationManager NavigationManager;
@inject ISnackbar Snackbar;


<section class="min-vh-100 d-flex align-items-center bg-light">

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-12 col-md-8 col-lg-5">

                <div class="card border-0 shadow-lg">

                    <!-- Header -->
                    <div class="card-header border-0 bg-white py-4 text-center">

                        <h3 class="fw-bold mb-1">Welcome Back</h3>
                        <p class="text-muted mb-0">Please login to your account</p>

                    </div>

                    <!-- Body -->
                    <div class="card-body px-4 py-4">

                        <EditForm Model="LoginModel" FormName="Login" OnValidSubmit="OnLogin">

                            <DataAnnotationsValidator />

                            <!-- Email -->
                            <div class="mb-3">
                                <label for="email" class="form-label">Email</label>
                                <InputText class="form-control form-control-lg"
                                           id="email"
                                           @bind-Value="LoginModel.Email" />
                                <ValidationMessage For="() => LoginModel.Email" />
                            </div>

                            <!-- Password -->
                            <div class="mb-3">
                                <label for="password" class="form-label">Password</label>
                                <InputText class="form-control form-control-lg"
                                           id="password"
                                           type="password"
                                           @bind-Value="LoginModel.Password" />
                                <ValidationMessage For="() => LoginModel.Password" />
                            </div>

                            <!-- Button -->
                            <div class="d-grid mt-4">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    Login
                                </button>
                            </div>

                        </EditForm>

                    </div>

                    <!-- Footer -->
                    <div class="card-footer border-0 bg-white py-3 text-center">

                        <small class="text-muted">
                            Don’t have an account?
                            <a href="/register" class="text-decoration-none fw-semibold">
                                Sign up
                            </a>
                        </small>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

@code {

    [SupplyParameterFromForm(FormName = "Login")]
    public LoginRequest LoginModel { get; set; } = new LoginRequest();

    private async Task OnLogin()
    {
        try
        {
            var response = await AuthUseCase.LoginAsync(LoginModel);

            if (response.IsError)
            {
                Snackbar.Add(response.ResponseMessage);
                return;
            }

            if (response.IsSuccess)
            {
                NavigationManager.NavigateTo("/");
                Snackbar.Add(response.ResponseMessage);
            }
        }
        catch (Exception err)
        {
            Snackbar.Add(err.Message);
        }

    }

}