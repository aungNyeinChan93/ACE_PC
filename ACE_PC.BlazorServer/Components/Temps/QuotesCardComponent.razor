
<div class="container py-4">

    <div class="row g-4">

        @foreach (var quote in MyQuotes)
        {
            <div class="col-lg-12">
                <div class="card h-100 border-0 shadow-sm">

                    <div class="card-header bg-white">
                        <div class="d-flex justify-content-between align-items-center">

                            <div>
                                <h5 class="mb-0">@quote.Title</h5>
                                <small class="text-muted">
                                    By @quote.Author
                                </small>
                            </div>

                            <span class="badge bg-primary">
                                @quote.Category
                            </span>

                        </div>
                    </div>

                    <div class="card-body">

                        <p class="text-muted">
                            @quote.Content
                        </p>

                    </div>

                    <div class="card-footer bg-white">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>
                                <i class="bi bi-chat-dots"></i>
                                @quote.Comments.Count Comments
                            </div>

                            <div>
                                <i class="bi bi-heart"></i>
                                @quote.Likes.Count Likes
                            </div>

                        </div>

                        @if (quote.Comments.Any())
                        {
                            <hr />

                            <h6>Recent Comments</h6>

                            @foreach (var comment in quote.Comments.Take(3))
                            {
                                <div class="mb-2 rounded border p-2">

                                    <strong>@comment.UserName</strong>

                                    <p class="small text-muted mb-0">
                                        @comment.Content
                                    </p>

                                </div>
                            }
                        }

                    </div>

                </div>
            </div>
        }

    </div>

</div>

@code {
    [Parameter]
    public List<QuotesDto> MyQuotes { get; set; } = new();

       
} 
